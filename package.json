  },
  "devDependencies": {
    "@tinacms/cli": "^2.3.1",
    "@types/node": "^22.18.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.33"
  }
